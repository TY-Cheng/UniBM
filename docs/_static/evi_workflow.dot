digraph EVIWorkflow {
    rankdir=LR;
    graph [fontsize=10];
    node [shape=box, style="rounded,filled", fillcolor="#edf7f5", color="#0f766e", fontname="Helvetica"];
    edge [color="#0f766e"];

    raw [label="Observed raw series"];
    blocks [label="Block extraction over candidate block sizes"];
    summaries [label="Block-summary curve\nQ_tau(M_b), mean(M_b), or mode(M_b)"];
    plateau [label="Observed plateau selection\non log(summary) vs log(block size)"];
    bootstrap [label="Bootstrap block-summary draws\nfrom the original series"];
    covariance [label="Cross-block covariance\nfor FGLS"];
    fit [label="Observed scaling fit\nxi = slope on selected plateau"];
    design [label="Design-life mapping\nEvaluate the same fitted law at larger block sizes"];

    raw -> blocks -> summaries -> plateau -> fit -> design;
    raw -> bootstrap -> covariance -> fit;
}
