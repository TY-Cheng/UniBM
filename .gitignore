# ==============================================================================
# Project-specific generated artifacts
# ==============================================================================
.python-version
/doc/
/out/
/data/
scratch*
*.pkl
*.csv.gz
*.npz
UniBM_manuscript/

# Keep the generated research notebook under version control.
# (Currently no blanket *.ipynb ignore exists, but this documents intent
#  and future-proofs in case one is added.)
!/scripts/vignette.ipynb

# ==============================================================================
